\begin{document}

\title{Life-cycle model with search frictions and skills}
\author{}
\date{\today}
\maketitle

\section{Model}

An individual is characterized by current assets $a\geq 0$, employment
status $\ell \in \{0,1\}$, skill level $g\in \{\bar{g}_{1},\ldots ,\bar{g}%
_{n_{g}}\}$, age $j\in \{1,\ldots ,J\}$ and a fixed education type, $%
educ_{i}=\{low,high\}$. Here $\ell =0$ denotes unemployment and $\ell =1$
denotes employment. Retirement begins at age $J_{R}$.

At each age, the individual chooses next-period assets $a^{\prime }\geq 0$
and search effort $s\geq 0$. Search effort matters only while the agent is
unemployed and of working age, that is, when $\ell =0$ and $j<J_{R}$. In all
other states the economically relevant choice is $s=0$.

Education affects the economic environment in two ways: on one hand it
reduced the risk of losing job, on the other hand it gives a wage premium.

The finite-horizon Bellman equation is 
\begin{equation*}
V_{i}(a,\ell ,g,j)=\max_{a^{\prime }\geq 0,\,s\geq 0}\left\{ u(c)-\kappa
(s)+\beta \sum_{\ell ^{\prime }}\sum_{g^{\prime }}V_{i}(a^{\prime },\ell
^{\prime },g^{\prime },j+1)\,\pi _{\ell }(\ell ,\ell ^{\prime }\mid s,\theta
_{i})\,\pi _{g}(g,g^{\prime }\mid \ell ,j)\right\} ,
\end{equation*}%
for $j=1,\ldots ,J$, with terminal condition 

\begin{equation*}
V_{i}(a,\ell ,g,J+1)=0.
\end{equation*}

The period budget constraint is 
\begin{equation*}
\left\{ 
\begin{array}{ll}
c+a^{\prime }=(1+r)a+educ_{i}\ w\ g\ \mathbb{I}_{\{\ell =1\}}+educ_{i}\ b\,%
\mathbb{I}_{\{\ell =0\}}, & j<J_{R}, \\ 
c+a^{\prime }=(1+r)a+educ_{i}\ pen, & j\geq J_{R}.%
\end{array}%
\right. 
\end{equation*}%
Thus, labor income equals wage $w$ times skill $g$ times education premium $%
educ_{i}$ when employed, unemployed workers receive benefit $b\ast educ_{i}$%
, and retirees receive pension income $pen\ast educ_{i}$.

In the current implementation, period utility is 
\begin{equation*}
u(c)=\frac{c^{1-\gamma}}{1-\gamma}, \qquad \kappa(s)=B_s s, 
\end{equation*}
and infeasible choices are ruled out by imposing $c>0$.

Employment transitions depend on search effort: 
\begin{equation*}
\pi _{\ell }(\ell ,\ell ^{\prime }\mid s,i)=%
\begin{bmatrix}
& \ell ^{\prime }=0 & \ell ^{\prime }=1 \\ 
\ell =0 & 1-\pi ^{s}(s) & \pi ^{s}(s) \\ 
\ell =1 & \sigma (i) & 1-\sigma (i)%
\end{bmatrix}%
.
\end{equation*}%
An unemployed worker finds a job with probability $\pi ^{s}(s)$, while an
employed worker loses the job with probability $\sigma (i)$. The job loss
probability $\sigma (i)$ depends on the fixed education type: $\sigma
(low)>\sigma (high)$, reflecting that higher-education individuals face a
smaller risk of losing their job.

Skill transitions depend on current employment status. A simple three-state
illustration is 
\begin{equation*}
\pi _{g}(g,g^{\prime }\mid \ell =0,j)=%
\begin{bmatrix}
& g^{\prime }=\bar{g}_{1} & g^{\prime }=\bar{g}_{2} & g^{\prime }=\bar{g}_{3}
\\ 
g=\bar{g}_{1} & 1 & 0 & 0 \\ 
g=\bar{g}_{2} & 1-p_{0} & p_{0} & 0 \\ 
g=\bar{g}_{3} & 0 & 1-p_{0} & p_{0}%
\end{bmatrix}%
,
\end{equation*}%
and 
\begin{equation*}
\pi _{g}(g,g^{\prime }\mid \ell =1,j)=%
\begin{bmatrix}
& g^{\prime }=\bar{g}_{1} & g^{\prime }=\bar{g}_{2} & g^{\prime }=\bar{g}_{3}
\\ 
g=\bar{g}_{1} & p_{1}^{j} & 1-p_{1}^{j} & 0 \\ 
g=\bar{g}_{2} & 0 & p_{1}^{j} & 1-p_{1}^{j} \\ 
g=\bar{g}_{3} & 0 & 0 & 1%
\end{bmatrix}%
.
\end{equation*}%
Under this ladder structure, unemployment weakly depreciates skills, while
employment weakly improves them. The age index in $p_{1}^{j}$ allows skill
accumulation to be stronger earlier in the life cycle.

\subsection{Distribution}

Let $\mu _{i}(a,\ell ,g,j)$ denotes the cross-sectional distribution over
individual states for permanent type $\theta _{i}$.

Given policy functions for next-period assets%
\begin{equation*}
Pol_{a^{\prime }}(a,\ell ,g,j,\theta _{i})
\end{equation*}%
and search effort%
\begin{equation*}
Pol_{s}(a,\ell ,g,j,\theta _{i})
\end{equation*}

